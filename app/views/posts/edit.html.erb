<%= form_with model: @own_post, class: "space-y-6 w-3/4 max-w-lg bg-white p-6 rounded-lg shadow" do |f| %>
  <label class="block text-xl font-bold text-gray-700">学習ログ編集</label>
 
  <div class="mt-1">
    <%= f.label :title, 'タイトル', class: "text-gray-700 text-lg" %>
    <%= f.text_field :title, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 mt-1 py-1 px-2 block w-full sm:text-sm placeholder-gray-400 border border-gray-300 rounded-md" %>
  </div>
 
  <div class="mt-1">
    <%= f.label :content, '本文', class: "text-gray-700 text-lg" %>
    <%= f.text_area :content, rows: "5", class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 mt-1 py-1 px-2 block w-full sm:text-sm placeholder-gray-400 border border-gray-300 rounded-md" %>
  </div>
 
  <p class="mt-2 text-sm text-gray-500">
    学習したこと、開発したことを記録しましょう。
  </p>
 
  <div class="px-2 py-3 text-right sm:px-3">
    <%= link_to "キャンセル", posts_path, class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-slate-500 hover:bg-slate-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 hover:cursor-pointer"%>
    <%= f.submit "ログを更新", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 hover:cursor-pointer" %>
  </div>
<% end %>